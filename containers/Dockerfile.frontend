# ─── raulglez-frontend (~80 MB) ────────────────────────────────────
# nginx:alpine + archivos estáticos
# Se reconstruye solo cuando cambia frontend/**

FROM nginx:alpine

COPY frontend/dist /usr/share/nginx/html

# Proxy /api/* al backend
COPY containers/nginx-frontend.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
