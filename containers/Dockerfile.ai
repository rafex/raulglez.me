# ─── raulglez-ai (~2.5 GB) — IMAGEN ESTÁTICA ──────────────────────
# Node.js + Python + sentence-transformers + FAISS.
# Solo se reconstruye cuando cambia backend/ai/** o backend/src/ai.ts.
# Los scripts (rag_faiss.py) y datos (cv.json, sqlite) se montan vía volumen.

FROM node:lts-slim AS builder

WORKDIR /app

COPY backend/package*.json ./
RUN npm ci

COPY backend/ ./
RUN npm run build


FROM node:lts-slim AS runtime

# ── Python + dependencias (STATIC LAYER, nunca cambia) ─────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      python3 \
      python3-pip \
      curl \
      ca-certificates \
      libgomp1 && \
    rm -rf /var/lib/apt/lists/* && \
    pip3 install --break-system-packages --no-cache-dir \
      sentence-transformers \
      faiss-cpu \
      numpy

RUN groupadd -g 1001 appgroup && \
    useradd -u 1001 -g appgroup -m -s /usr/sbin/nologin appuser

WORKDIR /app

# ── Código Node.js compilado ───────────────────────────────────────
COPY --from=builder --chown=appuser:appgroup /app/dist ./dist
COPY --from=builder --chown=appuser:appgroup /app/node_modules ./node_modules

# ── Scripts y datos (se montan vía volumen en runtime) ────────────
COPY --from=builder --chown=appuser:appgroup /app/ai ./backend/ai
COPY --from=builder --chown=appuser:appgroup /app/data ./data

RUN mkdir -p /app/data/db /app/backend/ai/index && \
    chown -R appuser:appgroup /app/data /app/backend

USER appuser

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -fsS http://localhost:3001/health || exit 1

CMD ["node", "dist/ai-server.js"]
