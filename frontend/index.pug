doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(name="description" content="CV Profesional — Raúl Eduardo González Argote")
    meta(name="author" content="Raúl González")
    meta(property="og:title" content="Raúl González — CV Profesional")
    meta(property="og:description" content="Arquitecto TI con 14+ años de experiencia en desarrollo de software empresarial")
    meta(property="og:type" content="website")
    title Raúl González — CV Profesional
    link(rel="stylesheet" href="/src/styles/main.css")
  body
