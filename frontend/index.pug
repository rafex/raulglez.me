doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(name="description" content="CV Profesional — Raúl Eduardo González Argote")
    meta(name="author" content="Raúl González")
    meta(property="og:title" content="Raúl González — CV Profesional")
    meta(property="og:description" content="Arquitecto TI con 14+ años de experiencia en desarrollo de software empresarial")
    meta(property="og:type" content="website")
    title Raúl González — CV Profesional
    link(rel="stylesheet" href="/src/styles/main.css")
  body
    button#a11y-toggle.a11y-toggle(type="button" aria-expanded="false" aria-controls="a11y-panel" title="Opciones de accesibilidad") Accesibilidad
    .reading-fab(aria-label="Modo lectura")
      span.reading-fab__label Modo lectura
      label.switch-button(for="reading-switch")
        .switch-outer
          input#reading-switch(type="checkbox" aria-label="Activar modo lectura")
          .button
            span.button-toggle
            span.button-indicator
    aside#a11y-panel.a11y-panel(aria-labelledby="a11y-title" hidden)
      h2#a11y-title Accesibilidad
      .a11y-group
        label(for="a11y-font-size") Tamaño de fuente
        input#a11y-font-size(type="range" min="90" max="130" step="5" value="100")
        p#a11y-font-size-value 100%
      .a11y-group
        label(for="a11y-font-family") Tipo de fuente (Open Source)
        select#a11y-font-family
          option(value="source") Source Sans 3
          option(value="atkinson") Atkinson Hyperlegible
          option(value="noto") Noto Sans
      .a11y-group
        label(for="a11y-color-theme") Paleta para daltonismo
        select#a11y-color-theme
          option(value="default") Azul profesional (base)
          option(value="protanopia") Protanopia-friendly
          option(value="deuteranopia") Deuteranopia-friendly
          option(value="tritanopia") Tritanopia-friendly
          option(value="contrast") Alto contraste
      .a11y-group
        p Usa el switch flotante "Modo lectura" para simplificar la vista.
    main#app
      header.cv-header
      section.section.cv-about
      section.section.cv-experience
      section.section.cv-skills
      section.section.cv-education
      section.section.cv-conferences
      section.section.cv-projects
      footer.section.cv-contact
    script(type="module" src="/src/scripts/main.ts")
