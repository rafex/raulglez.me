section#education.cv__section(data-animate="fadeInUp")
  .section__container
    h2.section__title Certificaciones
    .certifications__grid
      each cert in certifications
        .certification__card(data-animate="flipInX")
          .cert__icon 🏅
          .cert__info
            h3.cert__title= cert.title
            p.cert__details
              span.cert__code= cert.code
              | &nbsp;—&nbsp;
              span.cert__year= cert.year
            p.cert__id ID: #{cert.id}
