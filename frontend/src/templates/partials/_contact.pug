section#contact.cv__section(data-animate="fadeInUp")
  .section__container
    h2.section__title Contacto
    .contact__info
      .contact__item
        span.contact__icon 📱
        span= contact.phone
      .contact__item
        span.contact__icon ✉️
        a(href=`mailto:${contact.email}`)= contact.email
      .contact__item
        span.contact__icon 📍
        span= contact.location
      .contact__item
        span.contact__icon 🌐
        a(href=`https://${contact.website}` target="_blank" rel="noopener noreferrer")= contact.website
