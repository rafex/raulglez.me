        //
          // Panel IA movido a sección administrativa con autenticación.
          //
    aside#a11y-panel.a11y-panel(aria-labelledby="a11y-title" hidden)
      h2#a11y-title Accesibilidad
      .a11y-group
        label(for="a11y-font-size") Tamaño de fuente
        input#a11y-font-size(type="range" min="90" max="130" step="5" value="100")
        p#a11y-font-size-value 100%
      .a11y-group
        label(for="a11y-font-family") Tipo de fuente (Open Source)
        select#a11y-font-family
          option(value="source") Source Sans 3
          option(value="atkinson") Atkinson Hyperlegible
          option(value="noto") Noto Sans
      .a11y-group
        label(for="a11y-color-theme") Paleta para daltonismo
        select#a11y-color-theme
          option(value="default") Azul profesional (base)
          option(value="protanopia") Protanopia-friendly
          option(value="deuteranopia") Deuteranopia-friendly
          option(value="tritanopia") Tritanopia-friendly
          option(value="contrast") Alto contraste
      .a11y-group
        p Usa el switch flotante "Modo lectura" para simplificar la vista.
    main#app
      div#cv-header.cv-header(data-aos="fade-down")
      section#about.section.cv-about(data-aos="fade-up")
      section#experience.section.cv-experience(data-aos="fade-up")
      section#skills.section.cv-skills(data-aos="fade-up")
      section#education.section.cv-education(data-aos="fade-up")
      section#conferences.section.cv-conferences(data-aos="fade-up")
      section#articles.section.cv-articles(data-aos="fade-up")
      section#projects.section.cv-projects(data-aos="fade-up")
      //- Formulario de contacto
      section#contact-form.section.contact-section(data-aos="fade-up")
        .section__header
          h2 Contáctame
          p.section__subtitle ¿Interesado en colaborar? Déjame tus datos y me pondré en contacto.
        form#contact-me-form.contact-form(novalidate)
          .contact-form__row
            .contact-form__field
              label(for="contact-name") Nombre *
              input#contact-name(type="text" name="name" required placeholder="Tu nombre completo")
            .contact-form__field
              label(for="contact-email") Correo electrónico *
              input#contact-email(type="email" name="email" required placeholder="tu@email.com")
          .contact-form__row
            .contact-form__field
              label(for="contact-phone") Teléfono / WhatsApp *
              input#contact-phone(type="tel" name="phone" required placeholder="+52 55 1234 5678")
            .contact-form__field
              label(for="contact-company") Empresa
              input#contact-company(type="text" name="company" placeholder="Nombre de tu empresa")
          .contact-form__field
            label(for="contact-purpose") ¿En qué te puedo ayudar?
            select#contact-purpose(name="purpose")
              option(value="") Selecciona una opción...
              option(value="recruiting") Oportunidad laboral / Reclutamiento
              option(value="speaking") Ponencia / Conferencia
              option(value="workshop") Taller en universidad / empresa
              option(value="help") Ayuda técnica / Mentoría
              option(value="quote") Cotización de proyecto
          .contact-form__field
            label(for="contact-message") Mensaje
            textarea#contact-message(name="message" rows="4" placeholder="Cuéntame más sobre tu interés...")
          .contact-form__consent
            input#contact-consent(type="checkbox" name="consent" required)
            label(for="contact-consent") Acepto que mis datos sean utilizados para contactarme sobre esta solicitud. No compartiré tu información con terceros.
          button.contact-form__submit(type="submit") Enviar mensaje
        #contact-form-feedback.contact-form__feedback(aria-live="polite")
      footer#contact.section.cv-contact(data-aos="fade-up")
    //- Modal para descarga de PDF
    #pdf-modal.pdf-modal(hidden role="dialog" aria-labelledby="pdf-modal-title")
      .pdf-modal__overlay
      .pdf-modal__content
        button#pdf-modal-close.pdf-modal__close(type="button" aria-label="Cerrar") ✕
        h2#pdf-modal-title Descarga tu CV en PDF
        p.pdf-modal__desc Para descargar el CV, comparte tu correo y teléfono. Te enviaré el PDF con mis datos de contacto completos.
        form#pdf-download-form.pdf-download-form(novalidate)
          .pdf-download-form__field
            label(for="pdf-email") Correo electrónico *
            input#pdf-email(type="email" name="email" required placeholder="tu@email.com")
          .pdf-download-form__field
            label(for="pdf-phone") Teléfono / WhatsApp *
            input#pdf-phone(type="tel" name="phone" required placeholder="+52 55 1234 5678")
          .pdf-download-form__consent
            input#pdf-consent(type="checkbox" name="consent" required)
            label(for="pdf-consent") Acepto compartir mis datos para descargar el CV y recibir información de contacto.
          button.pdf-download-form__submit(type="submit") Descargar CV (PDF)
        #pdf-download-feedback.pdf-download-form__feedback(aria-live="polite")
    button#chat-toggle.chatBtn(type="button" aria-label="Abrir chat del CV" aria-controls="cv-chat-window" aria-expanded="false")
      svg(height="1.6em" fill="white" xml:space="preserve" viewBox="0 0 1000 1000" y="0px" x="0px" version="1.1" aria-hidden="true")
