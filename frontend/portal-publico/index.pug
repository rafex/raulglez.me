      span.tooltip Chat CV
    aside#cv-chat-window.cv-chat(hidden aria-live="polite")
      .cv-chat__header
        .cv-chat__title Chat CV
        button#chat-close.cv-chat__close(type="button" aria-label="Cerrar chat") ✕
      p.cv-chat__hint Para iniciar, comparte tus datos. Obligatorio: nombre y teléfono.
      form#chat-lead-form.cv-chat__lead
        input#lead-name(type="text" name="name" placeholder="Nombre *" required)
        input#lead-phone(type="tel" name="phone" placeholder="Teléfono / WhatsApp *" required)
        input#lead-email(type="email" name="email" placeholder="Correo electrónico")
        input#lead-company(type="text" name="company" placeholder="Empresa")
        input#lead-position(type="text" name="positionOffer" placeholder="Puesto a ofrecer")
      ul#chat-messages.cv-chat__messages
      form#chat-form.cv-chat__composer
        input#chat-question(type="text" placeholder="Escribe tu pregunta sobre el CV" minlength="8" required)
        button(type="submit") Enviar
