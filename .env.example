# Copia este archivo a .env para desarrollo local sin sops,
# o usa .env.enc con sops + age.

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# API
PORT=3000

# Panel Admin — crear estos secrets en GitHub Actions:
# GitHub → Settings → Secrets and variables → Actions → New repository secret
ADMIN_USER=admin
ADMIN_PASSWORD=                  # texto plano, o formato SALT:HASH (openssl)
SESSION_SECRET=                  # min 32 chars: openssl rand -hex 32
COOKIE_SECURE=false              # true en producción (Kubernetes con TLS en ingress)
